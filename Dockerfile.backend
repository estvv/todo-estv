FROM golang:1.21-alpine AS builder

WORKDIR /app

RUN apk add --no-cache gcc musl-dev

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=1 go build -o todo-server .

FROM alpine:latest

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/todo-server .

RUN mkdir -p /app/data

EXPOSE 3005

ENV DB_PATH=/app/data/todo.db
ENV PORT=3005

CMD ["./todo-server"]